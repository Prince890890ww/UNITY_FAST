{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "https://unityfast-production.up.railway.app/pair"
    },
    {
      "source": "/(.*)",
      "destination": "https://unityfast-production.up.railway.app/$1"
    }
  ]
}
