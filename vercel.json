{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-railway-app.up.railway.app/api/$1"
    },
    {
      "source": "/x",
      "destination": "https://your-railway-app.up.railway.app/x"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://your-railway-app.up.railway.app/socket.io/$1"
    }
  ]
}
